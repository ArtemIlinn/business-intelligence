# LinkedIn Interest Extractor - Environment Variables

# OpenAI API Key (recommended for cost-effectiveness)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Anthropic API Key (alternative LLM provider)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Optional: Proxycurl API Key (for production LinkedIn scraping)
# PROXYCURL_API_KEY=your-proxycurl-key

# Optional: Default LLM provider
# DEFAULT_LLM_PROVIDER=openai
